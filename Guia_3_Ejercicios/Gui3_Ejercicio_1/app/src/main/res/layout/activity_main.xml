<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#216EBC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        tools:context=".MainActivity">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="Ciclo de Vida Android" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="Activity principal" />

        <!-- Boton para abrir SecondActivity -->
        <Button
            android:id="@+id/btnAbrir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abrir nueva Activity"
            android:layout_marginVertical="20dp"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Boton para abrir ThirdActivity -->
        <Button
            android:id="@+id/btnTercera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ir a Third Activity"
            android:backgroundTint="#FF9800"
            android:layout_marginVertical="10dp"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Contador -->
        <Button
            android:id="@+id/btnIncrementar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incrementar"
            android:backgroundTint="#E91E63"
            android:layout_marginTop="20dp"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:text="Valor contador: 0" />

    </LinearLayout>
</ScrollView>